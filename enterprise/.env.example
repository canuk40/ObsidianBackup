# ===================================
# ObsidianBackup Enterprise Backend
# Environment Configuration Template
# ===================================
# 
# SECURITY WARNING: Never commit this file with actual credentials!
# Copy this file to .env and fill in your production values.
# 
# Generate secrets:
#   JWT_SECRET: openssl rand -base64 32
#   DATABASE_PASSWORD: openssl rand -base64 24
#   REDIS_PASSWORD: openssl rand -base64 24
# ===================================

# ===================================
# Environment
# ===================================
ENVIRONMENT=production
# Options: development, staging, production

# ===================================
# Server Configuration
# ===================================
SERVER_PORT=8080
# Server port (default: 8080)

# ===================================
# Database Configuration (PostgreSQL)
# ===================================
DATABASE_HOST=postgres
# PostgreSQL host (use service name in Docker Compose: "postgres")

DATABASE_PORT=5432
# PostgreSQL port (default: 5432)

DATABASE_NAME=obsidian_enterprise
# Database name

DATABASE_USER=obsidian_ent
# Database user (non-superuser recommended)

DATABASE_PASSWORD=
# ⚠️ CRITICAL: Generate strong password (min 20 characters)
# Example: openssl rand -base64 24

# ===================================
# Redis Configuration (JWT Blacklist)
# ===================================
REDIS_HOST=redis
# Redis host (use service name in Docker Compose: "redis")

REDIS_PORT=6379
# Redis port (default: 6379)

REDIS_PASSWORD=
# ⚠️ CRITICAL: Set strong password for production
# Example: openssl rand -base64 24

# ===================================
# JWT Authentication (Finding 6)
# ===================================
JWT_SECRET=
# ⚠️ CRITICAL: Generate 256-bit secret key
# Command: openssl rand -base64 32
# NEVER use default value in production!

JWT_ISSUER=ObsidianEnterprise
# JWT issuer claim

JWT_AUDIENCE=ObsidianBackupApp
# JWT audience claim

# ===================================
# SAML SSO Configuration (Finding 1)
# ===================================
SAML_ENABLED=false
# Enable SAML SSO (true/false)

SAML_ENTITY_ID=https://enterprise.obsidianbackup.com/saml/metadata
# SAML Service Provider Entity ID (your application)

SAML_IDP_METADATA_URL=
# SAML Identity Provider metadata URL
# Example (Okta): https://your-domain.okta.com/app/abc123/sso/saml/metadata
# Example (Azure AD): https://login.microsoftonline.com/{tenant-id}/federationmetadata/2007-06/federationmetadata.xml

SAML_IDP_ENTITY_ID=
# SAML Identity Provider Entity ID
# Example: http://www.okta.com/abc123xyz

# ===================================
# Firebase Cloud Messaging (Finding 3)
# ===================================
FCM_ENABLED=false
# Enable FCM for remote commands (true/false)

FCM_CREDENTIALS_PATH=/app/secrets/firebase-credentials.json
# Path to Firebase service account JSON file
# Mount as Docker secret or volume

FCM_PROJECT_ID=
# Firebase project ID
# Example: obsidian-backup-enterprise

# ===================================
# Audit Logging (Finding 8 - SOC 2)
# ===================================
AUDIT_RETENTION_DAYS=730
# Audit log retention period (730 = 24 months, SOC 2 requirement)

# ===================================
# Policy Engine (Finding 4)
# ===================================
POLICY_AUTO_REMEDIATION=true
# Enable automatic policy remediation (true/false)

# ===================================
# Monitoring & Observability (Finding 10)
# ===================================
# Prometheus Metrics
PROMETHEUS_ENABLED=true
# Enable Prometheus metrics endpoint

# Distributed Tracing (Zipkin)
ZIPKIN_ENABLED=false
# Enable distributed tracing (true/false)

ZIPKIN_URL=http://zipkin:9411
# Zipkin server URL

TRACING_SAMPLE_RATE=0.1
# Trace sampling rate (0.1 = 10% of requests)

# ===================================
# Logging Configuration
# ===================================
LOG_LEVEL_ROOT=INFO
# Root log level (ERROR, WARN, INFO, DEBUG, TRACE)

LOG_LEVEL_APP=DEBUG
# Application log level

LOG_LEVEL_SECURITY=INFO
# Security log level

LOG_LEVEL_SQL=WARN
# SQL log level (set to DEBUG to see queries)

# ===================================
# Email Notifications (Optional)
# ===================================
SMTP_HOST=
# SMTP server host (e.g., smtp.gmail.com)

SMTP_PORT=587
# SMTP server port (587 for TLS, 465 for SSL)

SMTP_USERNAME=
# SMTP username

SMTP_PASSWORD=
# SMTP password

SMTP_FROM_EMAIL=noreply@obsidianbackup.com
# From email address

# ===================================
# CORS Configuration
# ===================================
CORS_ALLOWED_ORIGINS=https://admin.obsidianbackup.com,https://enterprise.obsidianbackup.com
# Comma-separated list of allowed origins
# ⚠️ Never use "*" in production!

# ===================================
# Rate Limiting
# ===================================
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=5
# Authentication endpoint rate limit

RATE_LIMIT_API_REQUESTS_PER_MINUTE=100
# General API rate limit per user

# ===================================
# Session Configuration
# ===================================
SESSION_TIMEOUT_MINUTES=30
# Session timeout for web console

# ===================================
# Backup & Disaster Recovery
# ===================================
BACKUP_ENABLED=true
# Enable automated database backups

BACKUP_SCHEDULE_CRON=0 2 * * *
# Backup schedule (cron expression: daily at 2 AM)

BACKUP_RETENTION_DAYS=30
# Backup file retention period

BACKUP_S3_BUCKET=
# S3 bucket for backup storage (optional)

# ===================================
# Feature Flags
# ===================================
FEATURE_DEVICE_MANAGEMENT=true
FEATURE_POLICY_ENGINE=true
FEATURE_REMOTE_COMMANDS=true
FEATURE_AUDIT_LOGS=true
FEATURE_COMPLIANCE_REPORTS=true

# ===================================
# Development/Debug Settings
# ===================================
# ⚠️ ONLY enable in non-production environments!

DEBUG_ENABLED=false
# Enable debug mode (never in production)

SPRING_DEVTOOLS_ENABLED=false
# Enable Spring Boot DevTools (development only)

SQL_SHOW_QUERIES=false
# Show SQL queries in logs (development only)

# ===================================
# Cloud Provider Configuration (Optional)
# ===================================

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# GCP
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcp-credentials.json

# Azure
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ===================================
# Advanced Configuration
# ===================================

# Database Connection Pool
DATABASE_POOL_SIZE=20
DATABASE_POOL_MIN_IDLE=5
DATABASE_POOL_CONNECTION_TIMEOUT=30000

# Graceful Shutdown
SHUTDOWN_TIMEOUT_SECONDS=30

# Maximum Request Size
MAX_REQUEST_SIZE=10MB
MAX_FILE_SIZE=100MB

# ===================================
# Security Headers
# ===================================
SECURITY_HEADERS_HSTS_ENABLED=true
SECURITY_HEADERS_CSP_ENABLED=true
SECURITY_HEADERS_XSS_PROTECTION=true

# ===================================
# Compliance Frameworks
# ===================================
COMPLIANCE_FRAMEWORKS=SOC2,HIPAA,GDPR,PCI-DSS
# Comma-separated list of compliance frameworks to enforce

# ===================================
# NOTES
# ===================================
# 
# Production Deployment Checklist:
# --------------------------------
# [ ] Generate strong JWT_SECRET (openssl rand -base64 32)
# [ ] Set strong DATABASE_PASSWORD (min 20 chars)
# [ ] Set strong REDIS_PASSWORD (min 20 chars)
# [ ] Change default admin password in database
# [ ] Configure CORS_ALLOWED_ORIGINS (never use "*")
# [ ] Enable SAML_ENABLED if using SSO
# [ ] Configure FCM if using remote commands
# [ ] Set up SSL/TLS certificates
# [ ] Configure database backups
# [ ] Set up monitoring (Prometheus/Grafana)
# [ ] Configure log aggregation
# [ ] Test disaster recovery procedures
# [ ] Review and adjust rate limits
# [ ] Configure email notifications
# [ ] Set ENVIRONMENT=production
# 
# For detailed deployment instructions, see DEPLOYMENT.md
# ===================================
