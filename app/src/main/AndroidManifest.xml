<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Storage permissions for backup operations -->
    <!-- Legacy storage permissions for Android 9 and below -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    
    <!-- Media permissions for Android 13+ (API 33+) - Optional for user exports -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"
        android:minSdkVersion="33" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO"
        android:minSdkVersion="33" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO"
        android:minSdkVersion="33" />
    
    <!-- MANAGE_EXTERNAL_STORAGE - Only used for root/Shizuku advanced features
         App primarily uses app-private storage (getExternalFilesDir) which doesn't require this -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        android:minSdkVersion="30"
        tools:ignore="ScopedStorage" />

    <!-- Network permissions for cloud sync -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- WorkManager permissions -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    
    <!-- Syncthing permissions -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"
        android:minSdkVersion="34" />
    
    <!-- Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"
        android:minSdkVersion="33" />
    
    <!-- Biometric authentication -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    
    <!-- Haptic feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />
    
    <!-- Exact alarms for scheduled backups (Android 12+) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"
        android:minSdkVersion="31" />
    
    <!-- QR Code scanning (optional) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.biometric" android:required="false" />

    <!-- Root/Shizuku detection -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />
    
    <!-- SMS/MMS backup (root auto-grants READ_SMS) -->
    <uses-permission android:name="android.permission.READ_SMS" />

    <!-- Call log backup -->
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.WRITE_CALL_LOG" />

    <!-- Contacts backup -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />

    <!-- Wallpaper backup -->
    <uses-permission android:name="android.permission.SET_WALLPAPER" />


    <!-- Custom permissions for secure component access -->
    
    <!-- Permission for Tasker/automation integrations -->
    <permission
        android:name="com.obsidianbackup.permission.AUTOMATION"
        android:label="@string/permission_automation_label"
        android:description="@string/permission_automation_description"
        android:protectionLevel="signature|privileged"
        android:icon="@mipmap/ic_launcher" />
    
    <!-- Permission for Tasker status queries -->
    <permission
        android:name="com.obsidianbackup.permission.TASKER_STATUS"
        android:label="@string/permission_tasker_status_label"
        android:description="@string/permission_tasker_status_description"
        android:protectionLevel="signature"
        android:icon="@mipmap/ic_launcher" />
    
    <!-- Permission for Wear OS data sync -->
    <permission
        android:name="com.obsidianbackup.permission.WEAR_SYNC"
        android:label="@string/permission_wear_sync_label"
        android:description="@string/permission_wear_sync_description"
        android:protectionLevel="signature"
        android:icon="@mipmap/ic_launcher" />

    <application
        android:name=".ObsidianBackupApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ObsidianBackup"
        android:requestLegacyExternalStorage="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="false"
        tools:targetApi="q">

        <!-- WorkManager initialization -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Required by Health Connect to show its permission dialog.
                 Without this intent-filter the permission request silently fails. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity>

        <!-- Deep Link Activity - handles obsidianbackup:// scheme -->
        <!-- SECURITY WARNING: Custom URI schemes (obsidianbackup://) are vulnerable to URI
             interception attacks. This app implements signature verification to only accept
             deep links from trusted sources (see DeepLinkSecurityValidator.kt).
             
             RECOMMENDED: Use HTTPS app links (https://obsidianbackup.app/*) instead whenever
             possible. These are verified by Android's App Link system and are more secure.
             
             Custom scheme usage:
             - obsidianbackup://backup - trigger backup
             - obsidianbackup://restore?id=123 - restore specific snapshot
             - obsidianbackup://settings - open settings
             
             HTTPS app links (preferred, auto-verified):
             - https://obsidianbackup.app/backup
             - https://obsidianbackup.app/restore?id=123
             - https://obsidianbackup.app/settings
        -->
        <activity
            android:name=".deeplink.DeepLinkActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:launchMode="singleTop">
            
            <!-- Custom URI scheme: obsidianbackup://
                 SECURITY: Requires signature verification (see DeepLinkSecurityValidator)
                 Only trusted apps in whitelist can trigger these links
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                
                <data android:scheme="obsidianbackup" />
            </intent-filter>
            
            <!-- HTTPS App Links - obsidianbackup.app
                 SECURITY: Automatically verified by Android (safer than custom schemes)
                 Requires assetlinks.json hosted at https://obsidianbackup.app/.well-known/assetlinks.json
            -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                
                <data android:scheme="https" />
                <data android:host="obsidianbackup.app" />
                <data android:pathPrefix="/backup" />
            </intent-filter>
            
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                
                <data android:scheme="https" />
                <data android:host="obsidianbackup.app" />
                <data android:pathPrefix="/restore" />
            </intent-filter>
            
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                
                <data android:scheme="https" />
                <data android:host="obsidianbackup.app" />
                <data android:pathPrefix="/settings" />
            </intent-filter>
            
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                
                <data android:scheme="https" />
                <data android:host="obsidianbackup.app" />
                <data android:pathPrefix="/cloud" />
            </intent-filter>
        </activity>

        <!-- Tasker/MacroDroid Integration Components -->
        
        <!-- BroadcastReceiver for automation intents
             Protected by signature permission - only apps signed with same key can send intents.
             Tasker integration requires matching signature or system privileges. -->
        <receiver
            android:name=".tasker.TaskerIntegration"
            android:exported="true"
            android:enabled="true"
            android:permission="com.obsidianbackup.permission.AUTOMATION">
            <intent-filter>
                <action android:name="com.obsidianbackup.tasker.ACTION_START_BACKUP" />
                <action android:name="com.obsidianbackup.tasker.ACTION_RESTORE_SNAPSHOT" />
                <action android:name="com.obsidianbackup.tasker.ACTION_QUERY_STATUS" />
                <action android:name="com.obsidianbackup.tasker.ACTION_TRIGGER_CLOUD_SYNC" />
                <action android:name="com.obsidianbackup.tasker.ACTION_VERIFY_BACKUP" />
                <action android:name="com.obsidianbackup.tasker.ACTION_CANCEL_OPERATION" />
                <action android:name="com.obsidianbackup.tasker.ACTION_DELETE_SNAPSHOT" />
            </intent-filter>
        </receiver>

        <!-- ContentProvider for status queries
             Protected by signature permission - only apps signed with same key can query. -->
        <provider
            android:name=".tasker.TaskerStatusProvider"
            android:authorities="com.obsidianbackup.tasker"
            android:exported="true"
            android:enabled="true"
            android:readPermission="com.obsidianbackup.permission.TASKER_STATUS" />

        <!-- Wear OS Data Layer Listener Service
             Protected by signature permission - only Wear OS apps with same signature can connect.
             Additional runtime validation in PhoneDataLayerListenerService. -->
        <service
            android:name=".wear.PhoneDataLayerListenerService"
            android:exported="true"
            android:permission="com.obsidianbackup.permission.WEAR_SYNC">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data
                    android:host="*"
                    android:scheme="wear" />
            </intent-filter>
        </service>

        <!-- Widgets -->
        
        <!-- Quick Backup Widget -->
        <receiver
            android:name=".widget.BackupWidget"
            android:exported="true"
            android:label="@string/widget_backup_description">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/backup_widget_info" />
        </receiver>

        <!-- Backup Status Widget -->
        <receiver
            android:name=".widget.BackupStatusWidget"
            android:exported="true"
            android:label="@string/widget_status_description">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/backup_status_widget_info" />
        </receiver>

        <!-- Boot receiver for re-arming backup schedules -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="false"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- Foreground service for backup task execution -->
        <service
            android:name=".service.BackupTaskService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- FileProvider for sharing config files -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>